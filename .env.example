# ═══════════════════════════════════════════════════════════
# CES Service Backend — environment template
# Copy to .env and fill values:  cp .env.example .env
# docker-compose.yml in this folder reads these automatically.
# Never commit the real .env (it is .gitignore'd).
# ═══════════════════════════════════════════════════════════

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_DB=ces_service_db
POSTGRES_USER=ces_service_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_PORT=5432

# ── Redis ───────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_PORT=6379

# ── Backend ─────────────────────────────────────────────────
BACKEND_PORT=8080
SPRING_PROFILES_ACTIVE=dev          # dev = Swagger on; prod = Swagger off
LOG_LEVEL=DEBUG

# ── JWT (generate: openssl rand -base64 48) ─────────────────
JWT_SECRET=CHANGE_ME_BASE64_SECRET_AT_LEAST_256_BIT
JWT_EXPIRATION_MS=3600000
JWT_REFRESH_EXPIRATION_MS=604800000

# ── CES ERP integration ─────────────────────────────────────
CES_ERP_BASE_URL=http://host.docker.internal:9090
CES_ERP_API_KEY=CHANGE_ME_ERP_API_KEY

# ── File storage ────────────────────────────────────────────
STORAGE_BASE_URL=http://host.docker.internal:9000

# ── Seed admin (V6 migration / first login) ─────────────────
ADMIN_INIT_EMAIL=admin@ces.az
ADMIN_INIT_PASSWORD=Admin@123
ADMIN_INIT_FULL_NAME=System Administrator
